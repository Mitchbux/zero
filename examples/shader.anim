# ─────────────────────────────────────────────
# shader.anim  —  Zero Animation Framework
# GLSL procedural shader in a cinema-style frame
# with glowing borders and floating label badges
# ─────────────────────────────────────────────

Animation (
  title "Pixel Shader",
  fps "24",
  width "1280",
  height "720",
  duration "6.0",
  background "#03030a",

  # Outer glow frame — slightly larger than the shader box
  rect (
    x "9%",
    y "13%",
    width "82%",
    height "74%",
    color "rgba(0,0,0,0)",
    radius "22",
    fadein "0.0" "0.8",
    style.box_shadow "0 0 0 1px rgba(76,201,240,0.18), 0 0 40px 6px rgba(76,201,240,0.12), 0 0 100px 20px rgba(76,201,240,0.06)",
    style.outline "1px solid rgba(76,201,240,0.08)"
  )

  # Dark backing panel
  rect (
    x "11%",
    y "15%",
    width "78%",
    height "70%",
    color "#07070f",
    radius "18",
    border "1",
    bordercolor "rgba(76,201,240,0.15)",
    fadein "0.0" "0.6",
    style.box_shadow "0 4px 60px rgba(0,0,0,0.9), inset 0 0 120px rgba(0,0,0,0.5)"
  )

  # The GLSL shader
  shader (
    x "12%",
    y "17%",
    width "76%",
    height "66%",
    radius "12",
    fadein "0.3" "1.2",
    glsl "precision highp float;

    uniform sampler2D u_texture;
    uniform vec2 u_resolution;
    uniform float u_time;

    varying vec2 v_texCoord;

    void main() {

        vec4 image = texture2D(u_texture, v_texCoord);

        vec2 r = u_resolution;
        float t = u_time;

        vec2 p = vec2(v_texCoord.x, v_texCoord.y + 0.5) * vec2(r.x / r.y, 1.0);

        vec3 c = vec3(0.0);

        for (float i = 0.0; i < 42.0; i += 1.0) {
            float a = i / 1.5 + t * 0.5;
            vec2 q = p;

            q.x += sin(q.y * 19.0 + t * 2.0 + i) *
                   29.0 *
                   smoothstep(0.0, -2.0, q.y);

            float d = length(
                q - vec2(cos(a), sin(a)) * 0.4 *
                smoothstep(0.0, 0.5, -q.y)
            );

            c += vec3(0.14, 0.2, 0.34) * 0.015 / d;
        }

        vec3 effect = c * c + 0.05;
        vec3 finalColor = image.rgb + effect * 0.5;
        gl_FragColor = vec4(finalColor, 1.0);
    }"
  )

  # Top label bar background
  rect (
    x "11%",
    y "7%",
    width "78%",
    height "6%",
    color "rgba(7,7,18,0.85)",
    radius "10",
    border "1",
    bordercolor "rgba(76,201,240,0.12)",
    fadein "0.0" "0.8",
    style.backdrop_filter "blur(12px)",
    style.box_shadow "0 2px 20px rgba(0,0,0,0.5)"
  )

  # Title text
  text (
    content "Pixel Shader in a Box",
    x "50%",
    y "9.5%",
    color "#a8dadc",
    size "26",
    font "Georgia",
    weight "700",
    align "center",
    fadein "0.0" "1.0",
    style.filter "drop-shadow(0 0 10px rgba(168,218,220,0.7)) drop-shadow(0 0 25px rgba(76,201,240,0.35))",
    style.letter_spacing "3px"
  )

  # Bottom status bar background
  rect (
    x "11%",
    y "87%",
    width "78%",
    height "6%",
    color "rgba(7,7,18,0.85)",
    radius "10",
    border "1",
    bordercolor "rgba(76,201,240,0.12)",
    fadein "0.4" "1.0",
    style.backdrop_filter "blur(12px)",
    style.box_shadow "0 2px 20px rgba(0,0,0,0.5)"
  )

  # Bottom label — live indicator dot (rect as pill)
  rect (
    x "13%",
    y "88.5%",
    width "8",
    height "8",
    color "#f72585",
    radius "4",
    fadein "0.6" "1.0",
    style.box_shadow "0 0 8px #f72585, 0 0 18px rgba(247,37,133,0.6)"
  )

  # Bottom label text
  text (
    content "LIVE  —  WebGL · GLSL ES 1.00 · SwiftShader",
    x "51%",
    y "89.5%",
    color "rgba(168,218,220,0.55)",
    size "13",
    font "sans-serif",
    weight "400",
    align "center",
    fadein "0.6" "1.2",
    style.letter_spacing "2px"
  )

  # Top-left corner accent — horizontal
  rect (
    x "11%",
    y "15%",
    width "48",
    height "2",
    color "#4cc9f0",
    radius "1",
    fadein "0.3" "0.7",
    style.box_shadow "0 0 8px #4cc9f0, 0 0 20px rgba(76,201,240,0.5)"
  )

  # Top-left corner accent — vertical
  rect (
    x "11%",
    y "15%",
    width "2",
    height "36",
    color "#4cc9f0",
    radius "1",
    fadein "0.3" "0.7",
    style.box_shadow "0 0 8px #4cc9f0, 0 0 20px rgba(76,201,240,0.5)"
  )

)
