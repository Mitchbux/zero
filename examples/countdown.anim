# ─────────────────────────────────────────────
# countdown.anim  —  Zero Animation Framework
# Neon countdown with pulsing rings and explosive Go!
# ─────────────────────────────────────────────

Animation (
  title "Countdown",
  fps "24",
  width "1280",
  height "720",
  duration "5.0",
  background "#060610",

  # Outer ring — always present
  circle (
    cx "50%",
    cy "46%",
    r "245",
    color "rgba(0,0,0,0)",
    fadein "0.0" "0.5",
    fadeout "4.5" "5.0",
    style.box_shadow "0 0 0 3px rgba(100,80,140,0.25), 0 0 40px 8px rgba(100,80,140,0.12)"
  )

  # Inner circle — dark clock face
  circle (
    cx "50%",
    cy "46%",
    r "200",
    color "#100820",
    fadein "0.0" "0.5",
    fadeout "4.5" "5.0",
    style.box_shadow "0 0 0 2px rgba(80,60,120,0.3), 0 0 60px 30px rgba(60,40,100,0.2)"
  )

  # "3" — hot pink neon
  text (
    content "3",
    x "50%",
    y "26%",
    color "#f72585",
    size "230",
    font "Impact",
    weight "900",
    align "center",
    fadein "0.0" "0.3",
    fadeout "0.7" "1.0",
    scaleto "1.35" "0.0" "0.85",
    style.filter "drop-shadow(0 0 25px rgba(247,37,133,1)) drop-shadow(0 0 60px rgba(247,37,133,0.7)) drop-shadow(0 0 120px rgba(247,37,133,0.35))"
  )

  # Ring pulse for "3"
  circle (
    cx "50%",
    cy "46%",
    r "200",
    color "rgba(0,0,0,0)",
    fadein "0.0" "0.15",
    fadeout "0.5" "1.0",
    style.box_shadow "0 0 0 3px rgba(247,37,133,0.7), 0 0 30px 8px rgba(247,37,133,0.4), 0 0 80px 20px rgba(247,37,133,0.15)"
  )

  # "2" — violet neon
  text (
    content "2",
    x "50%",
    y "26%",
    color "#b5179e",
    size "230",
    font "Impact",
    weight "900",
    align "center",
    fadein "1.0" "1.3",
    fadeout "1.7" "2.0",
    scaleto "1.35" "1.0" "1.85",
    style.filter "drop-shadow(0 0 25px rgba(181,23,158,1)) drop-shadow(0 0 60px rgba(181,23,158,0.7)) drop-shadow(0 0 120px rgba(181,23,158,0.35))"
  )

  # Ring pulse for "2"
  circle (
    cx "50%",
    cy "46%",
    r "200",
    color "rgba(0,0,0,0)",
    fadein "1.0" "1.15",
    fadeout "1.5" "2.0",
    style.box_shadow "0 0 0 3px rgba(181,23,158,0.7), 0 0 30px 8px rgba(181,23,158,0.4), 0 0 80px 20px rgba(181,23,158,0.15)"
  )

  # "1" — deep indigo neon
  text (
    content "1",
    x "50%",
    y "26%",
    color "#7209b7",
    size "230",
    font "Impact",
    weight "900",
    align "center",
    fadein "2.0" "2.3",
    fadeout "2.7" "3.0",
    scaleto "1.35" "2.0" "2.85",
    style.filter "drop-shadow(0 0 25px rgba(114,9,183,1)) drop-shadow(0 0 60px rgba(114,9,183,0.7)) drop-shadow(0 0 120px rgba(114,9,183,0.35))"
  )

  # Ring pulse for "1"
  circle (
    cx "50%",
    cy "46%",
    r "200",
    color "rgba(0,0,0,0)",
    fadein "2.0" "2.15",
    fadeout "2.5" "3.0",
    style.box_shadow "0 0 0 3px rgba(114,9,183,0.7), 0 0 30px 8px rgba(114,9,183,0.4), 0 0 80px 20px rgba(114,9,183,0.15)"
  )

  # "Go!" — electric cyan explosion
  text (
    content "Go!",
    x "50%",
    y "26%",
    color "#4cc9f0",
    size "190",
    font "Impact",
    weight "900",
    align "center",
    fadein "3.0" "3.4",
    fadeout "4.2" "5.0",
    scaleto "0.55" "3.0" "3.5",
    style.filter "drop-shadow(0 0 30px rgba(76,201,240,1)) drop-shadow(0 0 70px rgba(76,201,240,0.8)) drop-shadow(0 0 140px rgba(76,201,240,0.4)) drop-shadow(0 0 240px rgba(76,201,240,0.2))"
  )

  # Explosion ring for "Go!"
  circle (
    cx "50%",
    cy "46%",
    r "200",
    color "rgba(0,0,0,0)",
    fadein "3.0" "3.2",
    fadeout "3.6" "4.0",
    style.box_shadow "0 0 0 4px rgba(76,201,240,0.9), 0 0 40px 12px rgba(76,201,240,0.5), 0 0 100px 30px rgba(76,201,240,0.2)"
  )

  # Footer brand tag
  text (
    content "Zero Animation Framework",
    x "50%",
    y "82%",
    color "rgba(255,255,255,0.22)",
    size "18",
    font "sans-serif",
    align "center",
    fadein "0.0" "1.0",
    fadeout "4.5" "5.0",
    style.letter_spacing "5px"
  )
)
